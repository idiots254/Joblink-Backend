# Joblink Backend Environment Variables

# Server Configuration
PORT=5000
NODE_ENV=development

# Email Verification Method
# Options: 'basic-format', 'mock-database', 'smtp'
# - basic-format: Only validates Gmail format (fastest, no real verification)
# - mock-database: Checks against test email list (good for dev/testing)
# - smtp: Actually connects to Gmail SMTP (most reliable, requires credentials)
EMAIL_VERIFICATION_METHOD=mock-database

# Gmail SMTP Credentials (only needed for 'smtp' method)
# Generate app password: https://myaccount.google.com/apppasswords
GMAIL_VERIFY_EMAIL=your-email@gmail.com
GMAIL_VERIFY_PASSWORD=your-16-char-app-password

# CORS Configuration
CORS_ORIGIN=http://localhost:8000,http://localhost:3000,http://localhost:5000

# Database (if you add database later)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=joblink
# DB_USER=postgres
# DB_PASSWORD=password
